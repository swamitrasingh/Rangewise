{
  "name": "rangewise",
  "version": "0.5.0",
  "description": "Rangewise is a UX-first date range formatter that intelligently adapts to context—showing only what matters, when it matters. ## Installation",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "vite demo",
    "release": "npm run build && npm version minor && git push --follow-tags && npm publish",
    "release:full": "git checkout main && git pull && git merge --no-ff HEAD@{1} && npm run build && npm version minor && git push --follow-tags && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swamitrasingh/Rangewise.git"
  },
  "keywords": [
    "date",
    "datetime",
    "date-range",
    "time-range",
    "date-format",
    "time-format",
    "datetime-format",
    "date-formatting",
    "time-formatting",
    "human-readable",
    "ux",
    "ui",
    "frontend",
    "i18n",
    "localization",
    "intl",
    "javascript",
    "typescript",
    "utility",
    "formatting",
    "time",
    "range",
    "rangewise"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/swamitrasingh/Rangewise/issues"
  },
  "homepage": "https://github.com/swamitrasingh/Rangewise#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
